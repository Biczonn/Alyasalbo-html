<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>My Webpage</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: Arial, sans-serif;
    }

    body {
      background-color: #111;
      color: #000;
    }

    /* Navbar */
    .navbar {
      background-color: #4CAF50;
      display: flex;
      justify-content: space-between;
      padding: 15px 30px;
      color: white;
    }

    .navbar h1 {
      font-size: 20px;
    }

    .nav-links a {
      color: white;
      text-decoration: none;
      margin-left: 20px;
      font-weight: bold;
    }

    /* Hero Section */
    .hero {
      background-color: #111;
      color: white;
      text-align: center;
      padding: 80px 20px;
      font-size: 36px;
      font-weight: bold;
    }

    /* About Section */
    .about {
      background-color: #ddd;
      text-align: center;
      padding: 40px 20px;
    }

    .about h2 {
      margin-bottom: 10px;
    }

    /* Projects */
    .projects {
      padding: 40px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }

    .project {
      background-color: #ddd;
      padding: 20px;
      text-align: center;
      font-size: 18px;
    }

    /* Footer */
    .footer {
      background-color: #333;
      color: white;
      text-align: center;
      padding: 15px;
    }
  </style>
</head>
<body>

  <!-- Navbar -->
  <div class="navbar">
    <h1>MyLogo</h1>
    <div class="nav-links">
      <a href="#">Home</a>
      <a href="#">About</a>
      <a href="#">Gallery</a>
      <a href="#">Contact</a>
    </div>
  </div>

  <!-- Hero Section -->
  <div class="hero">
    My Webpage
  </div>

  <!-- About Section -->
  <div class="about">
    <h2>About Me</h2>
    <p>im student of HTML.</p>
  </div>

  <!-- Projects -->
  <div class="projects">
    <div class="project">Project 1</div>
    <div class="project">Project 2</div>
    <div class="project">Project 3</div>
    <div class="project">Project 4</div>
  </div>

  <!-- Footer -->
  <div class="footer">
    © 2026 My Webpage | Designed by Me
  </div>

</body>
</html>
